# ===== Docker Compose 用の共通環境変数 =====
# このファイルを .env にコピーして使う

# --- PostgreSQL ---
POSTGRES_DB=memorise_development

# --- Backend (Rails) ---
DATABASE_HOST=db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
RAILS_ENV=development
# CORS 許可オリジン（フロントの URL）
FRONTEND_URL=http://localhost:3200
LOCAL_FRONTEND_URL=http://localhost:3200

# --- Frontend (Next.js) ---
# ブラウザから叩く GraphQL エンドポイント
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3100/graphql
